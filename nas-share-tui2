#!/bin/bash
# NAS SMB Admin - Versión Simplificada para LXC Unprivileged en Alpine

CONFIG_DIR="/etc/samba/smb.conf.d"
SMB_CONF_MAIN="/etc/samba/smb.conf"
SMB_DYNAMIC_CONF="/etc/samba/smb_dynamic.conf"
BACKUP_DIR="/root/samba_backups"
CONFIG_FILE="/root/.config/nas-share-tui/config"
EDITOR="vi" # 'vi' por defecto

# === Inicialización y Configuración ===
init_config() {
    mkdir -p "$CONFIG_DIR" "$BACKUP_DIR"
    grep -Fq "include = $SMB_DYNAMIC_CONF" "$SMB_CONF_MAIN" 2>/dev/null || \
        echo "include = $SMB_DYNAMIC_CONF" >> "$SMB_CONF_MAIN"
    [ -f "$SMB_DYNAMIC_CONF" ] || echo "" > "$SMB_DYNAMIC_CONF"
}

load_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    [ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"
}

change_editor() {
    echo "--- Selecciona editor por defecto ---"
    select choice in "vi" "nano" "Cancelar"; do
        case "$choice" in
            vi|nano)
                EDITOR="$choice"
                mkdir -p "$(dirname "$CONFIG_FILE")"
                echo "EDITOR=\"$EDITOR\"" > "$CONFIG_FILE"
                echo "[+] Editor establecido a '$EDITOR'."
                sleep 1
                break
                ;;
            "Cancelar") break ;;
            *) echo "[!] Opción inválida." ;;
        esac
    done
}

# === Habilitar/Deshabilitar al Inicio ===
toggle_samba_boot() {
    echo "--- Configurar Samba al Inicio del Sistema ---"
    echo "Estado actual:"
    if rc-update show default | grep -q "samba"; then
        echo "[Activo] Samba YA está configurado para iniciar automáticamente."
        echo ""
        read -p "¿Deseas DESHABILITAR el inicio automático? (s/n): " respuesta
        if [[ "$respuesta" =~ ^[sS]$ ]]; then
            rc-update del samba default >/dev/null 2>&1
            echo "[+] Samba eliminado del inicio automático."
        fi
    else
        echo "[Inactivo] Samba NO inicia automáticamente con el sistema."
        echo ""
        read -p "¿Deseas HABILITAR el inicio automático ahora? (s/n): " respuesta
        if [[ "$respuesta" =~ ^[sS]$ ]]; then
            rc-update add samba default >/dev/null 2>&1
            echo "[+] Samba configurado para iniciar automáticamente en el arranque."
        fi
    fi
    sleep 1.5
}

# === Mostrar Estado de Servicio y Boot ===
show_status() {
    echo "========================================="
    echo "       ESTADO DEL SERVICIO SAMBA         "
    echo "========================================="
    
    # 1. Estado en tiempo real (Proceso)
    echo -n " Proceso: "
    if rc-service samba status >/dev/null 2>&1; then
        echo -e "\e[32mEJECUTÁNDOSE (Started)\e[0m"
    else
        echo -e "\e[31mDETENIDO (Stopped)\e[0m"
    fi

    # 2. Estado del arranque (Boot)
    echo -n " Inicio automático (Boot): "
    if rc-update show default | grep -q "samba"; then
        echo -e "\e[32mHABILITADO (Enabled)\e[0m"
    else
        echo -e "\e[33mDESHABILITADO (Disabled)\e[0m"
    fi
    echo "========================================="
    echo ""
    # Muestra los detalles técnicos nativos de openrc abajo por si acaso
    rc-service samba status
    echo ""
    read -p "Presiona Enter para continuar..."
}

# === Backup y rollback ===
backup_dynamic() {
    cp "$SMB_DYNAMIC_CONF" "$BACKUP_DIR/smb_dynamic.conf.$(date +%Y%m%d%H%M%S)"
}

rollback_dynamic() {
    latest=$(ls -t "$BACKUP_DIR"/smb_dynamic.conf.* 2>/dev/null | head -n1)
    if [ -n "$latest" ]; then
        cp "$latest" "$SMB_DYNAMIC_CONF"
        rc-service samba restart >/dev/null 2>&1
        echo "[+] Rollback aplicado desde $latest"
    else
        echo "[!] No hay backups para rollback."
    fi
    sleep 1
}

reload_samba() {
    echo "[*] Verificando configuración con testparm..."
    if testparm -s "$SMB_DYNAMIC_CONF" >/dev/null 2>&1; then
        rc-service samba restart >/dev/null 2>&1
        echo "[+] Samba reiniciado OK."
    else
        echo "[!] Error de configuración. Revertiendo..."
        rollback_dynamic
    fi
    sleep 1
}

update_dynamic_smb_conf() {
    backup_dynamic
    if count=$(ls "$CONFIG_DIR"/*.conf 2>/dev/null) && [ -n "$count" ]; then
        cat "$CONFIG_DIR"/*.conf > "$SMB_DYNAMIC_CONF"
    else
        echo "" > "$SMB_DYNAMIC_CONF"
    fi
}

# === Validaciones ===
valid_share_name() {
    [[ "$1" =~ ^[a-zA-Z0-9._-]+$ ]]
}

# === Gestión de Shares ===
add_smb_share() {
    echo "--- Crear Nuevo Share ---"
    read -p "Nombre del share (Ej: media, documents): " share_name
    if ! valid_share_name "$share_name"; then
        echo "[!] Nombre inválido."
        sleep 1
        return
    fi

    echo "Introduce la ruta exacta del directorio a compartir."
    echo "Dejar en blanco usará directamente la raíz: /srv/data/"
    read -p "Ruta completa: " input_path

    local share_path
    if [[ -z "$input_path" ]]; then
        share_path="/srv/data/"
    elif [[ "$input_path" == /* ]]; then
        share_path="$input_path"
    else
        share_path="/srv/data/$input_path"
    fi

    if [[ ! -d "$share_path" ]]; then
        echo "[*] La ruta no existe. Creándola en: $share_path"
        mkdir -p "$share_path"
        chown root:root "$share_path" 2>/dev/null
    fi

    cat <<EOF > "$CONFIG_DIR/$share_name.conf"
[$share_name]
   path = $share_path
   browseable = yes
   writable = yes
   guest ok = no
   valid users = root
   force user = root
   force group = root
   create mask = 0664
   directory mask = 0775
EOF

    update_dynamic_smb_conf
    reload_samba
    echo "[+] Share SMB '$share_name' creado exitosamente apuntando a $share_path."
    sleep 1.5
}

list_and_edit_smb() {
    local files=($(ls "$CONFIG_DIR" 2>/dev/null))
    if [ ${#files[@]} -eq 0 ]; then
        echo "No hay shares para editar."
        sleep 1
        return
    fi

    echo "--- Selecciona share a editar ---"
    select file in "${files[@]}" "Cancelar"; do
        [[ "$file" == "Cancelar" || -z "$file" ]] && break
        $EDITOR "$CONFIG_DIR/$file"
        update_dynamic_smb_conf
        reload_samba
        break
    done
}

delete_smb_share() {
    local files=($(ls "$CONFIG_DIR" 2>/dev/null))
    if [ ${#files[@]} -eq 0 ]; then
        echo "Nada que borrar."
        sleep 1
        return
    fi

    echo "--- Selecciona share a ELIMINAR ---"
    select file in "${files[@]}" "Cancelar"; do
        [[ "$file" == "Cancelar" || -z "$file" ]] && break
        rm -f "$CONFIG_DIR/$file"
        update_dynamic_smb_conf
        reload_samba
        echo "[+] Share borrado."
        break
    done
    sleep 1
}

# === Gestión de Contraseña ===
change_root_password() {
    echo "--- Cambiar contraseña de root para acceder al NAS ---"
    smbpasswd root
    echo "[+] Contraseña de root actualizada en Samba."
    sleep 1.5
}

# === Utilidades ===
launch_monitor() {
    if ! command -v btop >/dev/null 2>&1; then
        echo "[*] Instalando btop..."
        apk add btop >/dev/null 2>&1
    fi
    btop
}

# === Menú principal ===
main_menu() {
    while true; do
        clear
        echo "========================================="
        echo "            NAS SMB ADMIN (LXC)           "
        echo "========================================="
        echo " Almacenamiento raíz: /srv/data/         "
        echo " Editor activo: $EDITOR                  "
        echo "========================================="
        echo "  1) Agregar nuevo share"
        echo "  2) Editar share existente"
        echo "  3) Borrar share"
        echo "-----------------------------------------"
        echo "  4) Cambiar contraseña de acceso (root)"
        echo "-----------------------------------------"
        echo "  5) Ver estado del servicio Samba"
        echo "  6) Reiniciar servicio Samba"
        echo "  7) Configurar Samba al inicio (Boot)"
        echo "  8) Ver monitor del sistema (btop)"
        echo "  9) Cambiar editor por defecto"
        echo "  10) Salir"
        echo "========================================="
        read -p "Opción [1-10]: " opt
        case $opt in
            1) add_smb_share ;;
            2) list_and_edit_smb ;;
            3) delete_smb_share ;;
            4) change_root_password ;;
            5) show_status ;;
            6) rc-service samba restart; echo "[+] Reiniciado."; sleep 1 ;;
            7) toggle_samba_boot ;;
            8) launch_monitor ;;
            9) change_editor ;;
            10) exit 0 ;;
            *) echo "Opción inválida" && sleep 1 ;;
        esac
    done
}

init_config
load_config
main_menu
